{
  "name": "scg-markdown",
  "version": "0.16.0",
  "description": "Schlanker Markdown-Editor für Windows 11 mit Tabs, Quellcode-/Render-Ansicht, Auto-Reload und Mehrsprachigkeit.",
  "main": "src/main/main.js",
  "scripts": {
    "start": "npm run build:renderer && electron .",
    "dev": "npm run build:renderer && electron . --enable-logging",
    "build:icon": "node scripts/build-icon.js",
    "build:renderer": "node scripts/build-renderer.js",
    "build": "npm run build:renderer && electron-builder --win",
    "build:installer": "npm run build:renderer && electron-builder --win nsis",
    "build:portable": "npm run build:renderer && electron-builder --win portable",
    "postbuild": "node scripts/archive-build.js",
    "postbuild:installer": "node scripts/archive-build.js",
    "postbuild:portable": "node scripts/archive-build.js"
  },
  "author": "Matthias Stumm <matthias@stumm-net.de>",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.28.0",
    "sharp": "^0.33.5",
    "to-ico": "^1.1.5"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@vscode/markdown-it-katex": "^1.1.2",
    "chokidar": "^4.0.1",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.8.3",
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.1.1",
    "katex": "^0.16.47",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.15.0"
  },
  "build": {
    "appId": "net.stumm.scg-markdown",
    "productName": "SCG Markdown",
    "copyright": "Copyright (c) 2026 Matthias Stumm",
    "publish": {
      "provider": "github",
      "owner": "MatthiasSCG",
      "repo": "SCG-Markdown"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json",
      "!src/assets/markdown-mark.svg",
      "!**/*.map"
    ],
    "asarUnpack": [
      "src/i18n/**/*"
    ],
    "win": {
      "icon": "src/assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SCG Markdown",
      "deleteAppDataOnUninstall": false,
      "uninstallDisplayName": "SCG Markdown",
      "artifactName": "${productName}-${version}-Setup.${ext}",
      "include": "build/installer.nsh"
    },
    "portable": {
      "artifactName": "${productName}-${version}-Portable.${ext}"
    }
  }
}

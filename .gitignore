# Dependencies
node_modules/

# Renderer-Bundle (wird vor jedem Electron-Start/Build per esbuild aus
# renderer.js und seinen Imports erzeugt; siehe scripts/build-renderer.js).
src/renderer/renderer.bundle.js

# 4T-0023: highlight.js-Themes werden vor dem Renderer-Build aus
# node_modules generiert (siehe scripts/build-hljs-themes.js).
src/renderer/hljs-themes.css

# 4T-0022: KaTeX-Assets (CSS und woff2-Fonts) werden vor dem Renderer-Build
# aus node_modules/katex kopiert (siehe scripts/build-katex-assets.js).
src/renderer/katex/

# 4T-0021: separater Mermaid-Bundle (Lazy-Load-Ziel; ~3MB minified).
# Wird vom Renderer per dynamischem import() nachgeladen (siehe
# scripts/build-mermaid.js).
src/renderer/mermaid.bundle.js

# Build-Ergebnisse (Output-Verzeichnisse)
dist/
out/
*.exe
*.msi
*.appx
# Hinweis: build/ ist NICHT ausgeschlossen — dort liegen Build-Ressourcen
# wie installer.nsh fuer electron-builder, die ins Repo gehoeren.

# Versions-Archiv der EXEs (per scripts/archive-build.js nach dem Build
# aus dist/ hierher verschoben). Die EXEs haengen am GitHub-Release und
# gehoeren nicht ins Repo.
releases/

# Logs
*.log
npm-debug.log*

# Editor-/Betriebssystem-Dateien
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Lokale Konfiguration
.env
.env.local
.claude/settings.local.json

# Electron User-Data (falls jemand per Symlink lokal testet)
userData/
